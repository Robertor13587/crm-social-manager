{
  "name": "whatsapp-instagram-manager",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc --noEmit && vite build",
    "preview": "vite preview",
    "lint": "eslint . --ext .vue,.js,.jsx,.cjs,.mjs,.ts,.tsx,.cts,.mts --fix --ignore-path .eslintignore",
    "test": "vitest",
    "type-check": "vue-tsc --noEmit",
    "api:dev": "node scripts/crm_api_server.js",
    "db:migrate": "node scripts/db_migrate.js",
    "db:migrate:supabase": "node scripts/migrate_mysql_to_supabase.js",
    "db:migrate:supabase:dry": "node scripts/migrate_mysql_to_supabase.js --dry-run"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.97.0",
    "@vueuse/core": "^10.5.0",
    "dotenv": "^17.2.3",
    "jsonwebtoken": "^9.0.3",
    "lucide-vue-next": "^0.294.0",
    "pinia": "^2.1.7",
    "vue": "^3.5.25",
    "vue-router": "^4.2.5"
  },
  "devDependencies": {
    "@rushstack/eslint-patch": "^1.5.1",
    "@tailwindcss/postcss": "^4.1.17",
    "@tsconfig/node18": "^18.2.2",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^22.12.0",
    "@vitejs/plugin-vue": "^6.0.2",
    "@vue/eslint-config-typescript": "^12.0.0",
    "@vue/test-utils": "^2.4.6",
    "@vue/tsconfig": "^0.4.0",
    "autoprefixer": "^10.4.16",
    "eslint": "^8.49.0",
    "eslint-plugin-vue": "^9.17.0",
    "jsdom": "^27.2.0",
    "postcss": "^8.4.31",
    "tailwindcss": "^3.4.17",
    "typescript": "~5.2.0",
    "vite": "^7.2.4",
    "vite-plugin-pwa": "^1.2.0",
    "vitest": "^4.0.14",
    "vue-tsc": "^3.1.5"
  }
}
